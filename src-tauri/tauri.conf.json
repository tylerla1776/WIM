{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WIM",
  "version": "2.2.0",
  "identifier": "com.wim.inventory",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "WIM — Warehouse Inventory Management",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/GITHUB_USER/GITHUB_REPO/releases/latest/download/latest.json"
      ],
      "pubkey": "PASTE_YOUR_TAURI_PUBLIC_KEY_HERE"
    }
  }
}
