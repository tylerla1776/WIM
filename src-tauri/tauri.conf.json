{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WIM",
  "version": "2.6.12",
  "identifier": "com.wim.inventory",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "WIM — Warehouse Inventory Management",
        "width": 470,
        "height": 470,
        "minWidth": 380,
        "minHeight": 360,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/tylerla1776/WIM/refs/heads/updater/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlDNEQ3MzlBRjg5QTE3MzYKUldRMkY1cjRtbk5ObkNWcmMwczJuZE1PM2s0a3lmL25sdGV1VnhKSnU0UkczQUc2UldyTkhzQS8K"
    }
  }
}
